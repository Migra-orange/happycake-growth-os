PORT=8787
VITE_API_BASE_URL=http://localhost:8787
PUBLIC_BASE_URL=http://localhost:5173
HAPPYCAKE_PUBLIC_BASE_URL=http://localhost:5173

# auto = use Claude Code CLI if present, else simulator
# live = require Claude Code CLI
# simulated = force deterministic fallback
ASSISTANT_MODE=simulated
CLAUDE_TIMEOUT_MS=90000

# Hackathon MCP sandbox. Do not commit real token.
# live = require real Steppe MCP calls; simulated = local deterministic fixtures only.
MCP_MODE=live
HAPPYCAKE_MCP_URL=https://www.steppebusinessclub.com/api/mcp
HAPPYCAKE_MCP_TEAM_TOKEN=REPLACE_WITH_STEPPE_TEAM_TOKEN

# Vercel Blob durable state. Do not commit real token.
BLOB_READ_WRITE_TOKEN=REPLACE_WITH_VERCEL_BLOB_TOKEN

# Owner/API protection. Do not commit real token.
OWNER_API_TOKEN=REPLACE_WITH_STRONG_OWNER_TOKEN

# Optional live Telegram owner bot/webhook. Do not commit real token/secret.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=REPLACE_WITH_TELEGRAM_BOT_USERNAME
TELEGRAM_OWNER_CHAT_ID=REPLACE_WITH_OWNER_CHAT_ID
TELEGRAM_OWNER_USER_ID=REPLACE_WITH_OWNER_USER_ID
TELEGRAM_ALLOWED_USERS=REPLACE_WITH_OWNER_USER_ID
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
